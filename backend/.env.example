# Your Serper dev api key
SERPER_API_KEY=your_serper_api_key_here

# Your MySQL database credentials
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Your HubSpot OAuth app credentials
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret

# Must exactly match the redirect URI you registered in HubSpot
HUBSPOT_REDIRECT_URI=http://localhost:8000/auth/hubspot/oauth-callback

# Used by Flask to sign its session cookies
FLASK_SECRET_KEY=your_flask_secret_key

# For encrypting API keys entered into model provider Settings modal
SETTINGS_ENCRYPTION_KEY=your_fernet_encryption_key

# Model provider API keys (optional)
#OPENROUTER_API_KEY=
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#GROQ_API_KEY=
#SAMBANOVA_API_KEY=
#GEMINI_API_KEY=

# Default model configuration
# DEFAULT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct
OLLAMA_API_BASE=

# Smart extraction configuration
SMART_EXTRACT_MAX_URLS=3
SMART_EXTRACT_MAX_CHARS_PER_URL=2000
SMART_EXTRACT_MAX_TOTAL_CHARS=5000
SMART_EXTRACT_REQUEST_DELAY=1.0

# Codex debugging
CODEX_DEBUG=false
