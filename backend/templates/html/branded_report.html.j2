<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or 'Report' }}</title>
    <style>
      :root {
        --bg: #0b0f14;
        --surface: #121824;
        --text: #e7eaf0;
        --muted: #9aa4b2;
        --brand: #8b5cf6; /* brand purple */
        --border: #2a3342;
      }
      @media print {
        :root { --bg: #ffffff; --surface: #ffffff; --text: #111827; --muted: #4b5563; --brand: #4f46e5; --border: #e5e7eb; }
      }
      body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Inter, Helvetica, Arial, sans-serif; line-height: 1.6; margin: 0; }
      .wrap { max-width: 860px; margin: 0 auto; padding: 32px 20px; }
      .header { border-bottom: 2px solid var(--brand); padding-bottom: 12px; margin-bottom: 20px; }
      h1 { margin: 0 0 6px; font-size: 28px; }
      .meta { color: var(--muted); font-size: 13px; }
      table.meta { width: 100%; border-collapse: collapse; margin-top: 10px; }
      table.meta th, table.meta td { text-align: left; font-size: 13px; padding: 6px 8px; border-bottom: 1px solid var(--border); }
      .content { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px 18px; }
      .content h2 { color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 6px; margin-top: 24px; }
      pre, code { background: #0f172a; color: #e2e8f0; border-radius: 6px; }
      pre { padding: 10px; overflow: auto; }
      a { color: var(--brand); text-decoration: none; }
      .status { display: inline-block; font-size: 12px; padding: 2px 8px; border-radius: 999px; border: 1px solid var(--border); color: var(--muted); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="header">
        <h1>{{ title }}</h1>
        <div class="meta">Exported {{ exported_at }}</div>
        <table class="meta">
          <tbody>
            {% if task_id %}<tr><th>Task ID</th><td>{{ task_id }}</td></tr>{% endif %}
            {% if model_name %}<tr><th>Model</th><td>{{ model_name }}</td></tr>{% endif %}
            {% if profile %}<tr><th>Profile</th><td>{{ profile }}</td></tr>{% endif %}
          </tbody>
        </table>
      </div>
      <div class="content">
        {{ content_html | safe }}
      </div>
    </div>
  </body>
  </html>

